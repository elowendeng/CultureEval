# .env.example - Environment configuration file template

# Alibaba Cloud DashScope API Configuration

DASHSCOPE_API_KEY=your_dashscope_api_key_here
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# Baidu Qianfan API Configuration

BAIDU_API_KEY=your_baidu_api_key_here
BAIDU_BASE_URL=https://qianfan.baidubce.com/v2/chat/completions

# Zhipu AI API Configuration

GLM_API_KEY=your_zhipu_api_key_here

# Spark API Configuration

SPARK_API_KEY=your_spark_api_key_here
SPARK_API_SECRET=your_spark_api_secret_here